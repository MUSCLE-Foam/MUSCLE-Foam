FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      flux0;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 -2 -1 0 0 0 0];

internalField   uniform 1e13;

boundaryField
{
    movingWall
    {
        type            albedo;
        gamma           0.5;
        diffCoeffName   DAlbedo;
        fluxStarAlbedo  fluxAlbedo;
        forSecondMoment 0;
        value           uniform 0;
    }

    fixedWalls
    {
        type            albedo;
        gamma           0.5;
        diffCoeffName   DAlbedo;
        fluxStarAlbedo  fluxAlbedo;
        forSecondMoment 0;
        value           uniform 0;
    }

    frontAndBack
    {
        type            empty;
    }
}

