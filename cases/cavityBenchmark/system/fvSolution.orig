// ************************************************************************* //
FoamFile
{
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
    p_rgh
    {
        solver           GAMG;
        smoother         DICGaussSeidel;
        tolerance        1e-7;
        relTol           0.001;
        maxIter          VARUMAXITER;
    }

    p_rghFinal
    {
        $p_rgh;
        relTol          0;
    }

    "rho.*"
    {
        solver          diagonal;
        tolerance       1e-05;
        relTol          0;
    }

    h
    {
        // solver          smoothSolver;
        // smoother        symGaussSeidel;
        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-7;
        relTol          0.001;
        maxIter         VARHMAXITER;
    }

    hFinal
    {
        $h;
        relTol          0;
    }

    U
    {
        solver          smoothSolver;
        smoother        symGaussSeidel;
        tolerance       1e-6;
        relTol          0.001;
        maxIter         VARUMAXITER;
    }

    UFinal
    {
        $U;
        relTol          0;
    }

    "prec.*"
    {
        solver          GAMG;
        smoother        DILU;

        tolerance       1e-14;
        relTol          1e-8;
        maxIter         100;
    }

    "(prec.*)Final"
    {
        solver          GAMG;
        smoother        DILU;

        tolerance       1e-14;
        relTol          1e-8;
        maxIter         100;
    }

    "dec.*"
    {
        solver          GAMG;
        smoother        DILU;

        tolerance       1e-12;
        relTol          1e-4;
        maxIter         100;
    }

    "(dec.*)Final"
    {
        solver          GAMG;
        smoother        DILU;

        tolerance       1e-12;
        relTol          1e-4;
        maxIter         100;
    }

    "(flux|secondFlux).*"
    {
        solver          GAMG;
        smoother        DIC;

        tolerance       1e-14;
        relTol          1e-8;
        maxIter         100;
    }

    "((flux|secondFlux).*)Final"
    {
        solver          GAMG;
        smoother        DIC;

        tolerance       1e-14;
        relTol          1e-8;
        maxIter         100;
    }
}

PIMPLE
{
    momentumPredictor yes;
    nOuterCorrectors VAROUTERCORR;
    nCorrectors     2;
    nNonOrthogonalCorrectors 0;
    pRefCell        0;
    pRefValue       1e5;
}

NPIMPLE
{
    nOuterCorrectors VARNOUTERCORR;
}

relaxationFactors
{
    fields
    {
        p_rgh           0.3;
        p               0.3;
        rho             0.3;
    }
    equations
    {
        U               0.3;
        rho             0.3;
        p_rgh           0.3;
        p               0.3;
        h               0.3;
        "(k|epsilon|omega)" 0.3;
        "flux.*"        0.3;
        "prec.*"        0.3;
        "dec.*"         0.3;
    }
}

// ************************************************************************* //
