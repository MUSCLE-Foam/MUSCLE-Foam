// ************************************************************************* //
FoamFile
{
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
    p_rgh
    {
        solver           GAMG;
        smoother         DICGaussSeidel;
        tolerance        1e-7;
        relTol           0.01;
        maxIter          0;
    }

    p_rghFinal
    {
        $p_rgh;
        relTol          0;
    }

    "rho.*"
    {
        solver          diagonal;
        tolerance       1e-05;
        relTol          0;
    }

    h
    {
        // solver          smoothSolver;
        // smoother        symGaussSeidel;
        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-05;
        relTol          0.01;
        maxIter         0;
    }

    hFinal
    {
        $h;
        relTol          0;
    }

    U
    {
        solver          smoothSolver;
        smoother        symGaussSeidel;
        tolerance       1e-05;
        relTol          0.01;
        maxIter         0;
    }

    UFinal
    {
        $U;
        relTol          0;
    }

    "prec.*"
    {
        solver          GAMG;
        smoother        DILU;

        tolerance       1e-12;
        relTol          1e-4;
        maxIter         100;
    }

    "(prec.*)Final"
    {
        solver          GAMG;
        smoother        DILU;

        tolerance       1e-12;
        relTol          1e-4;
        maxIter         100;
    }

    "dec.*"
    {
        solver          GAMG;
        smoother        DILU;

        tolerance       1e-12;
        relTol          1e-4;
        maxIter         100;
    }

    "(dec.*)Final"
    {
        solver          GAMG;
        smoother        DILU;

        tolerance       1e-12;
        relTol          1e-4;
        maxIter         100;
    }

    "flux.*"
    {
        solver          GAMG;
        smoother        DILUGaussSeidel;

        tolerance       1e-12;
        relTol          1e-7;
        maxIter         100;
    }
}

PIMPLE
{
    momentumPredictor yes;
    nOuterCorrectors 0;
    nCorrectors     2;
    nNonOrthogonalCorrectors 0;
    pRefCell        0;
    pRefValue       1e5;
}

NPIMPLE
{
    nOuterCorrectors 1;
}

relaxationFactors
{
    fields
    {
    }
    equations
    {
        ".*"    1;
    }
}



